Class {
	#name : #GtLDataSourceEncoderExamples,
	#superclass : #Object,
	#traits : 'TAssertable',
	#classTraits : 'TAssertable classTrait',
	#category : #'Gt4Llm-DataSource-Examples'
}

{ #category : #examples }
GtLDataSourceEncoderExamples >> basicJsonPlaceholderTool [
	<gtExample>
	| requestHistory constructor chat message placeholderTool entity |

	requestHistory := GtLDataSourceEncoderDecoder loadClientHistoryFromStream: self ollamaJsonl1 readStream.
	chat := GtLChat new provider: (GtLOllamaProvider new
		modelName: 'qwen3.5:9b').
	constructor := GtLDataSourceMessageConstructor new
		requestHistory: requestHistory;
		chat: chat;
		parse.
	message := chat messages at: 1.
	self assert: message tools size equals: 1.
	placeholderTool := message tools first.
	self assert: placeholderTool class equals: GtLJsonPlaceholderTool.
	entity := placeholderTool entity.
	self assert: entity type equals: 'function'.
	self assert: entity name equals: 'WebFetch'.
	self assert: entity parameters keys asSet
		equals: #('type' 'properties' 'required' 'additionalProperties') asSet.

	^ placeholderTool
]

{ #category : #examples }
GtLDataSourceEncoderExamples >> encodeRequestResponse [
	<gtExample>
	| requestResponse encoder stream encoded decoder decoded |

	requestResponse := GtLRequestResponse new
		request: self requests1 first;
		response: self responses1 first.
	encoder := GtLDataSourceEncoderDecoder new.
	stream := (String new: 1024) writeStream.
	encoder encode: requestResponse on: stream.
	encoded := stream contents.

	decoder := GtLDataSourceEncoderDecoder new.
	decoded := decoder decodeRequestResponseOn: encoded readStream.

	self assert: decoded class identicalTo: GtLRequestResponse.
	^ decoded
]

