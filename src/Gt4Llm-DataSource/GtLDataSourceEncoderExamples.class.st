{ #category : #examples }
GtLDataSourceEncoderExamples >> ollamaChat1 [
	<gtExample>
	| requestHistory constructor chat message toolMessage finalMessage |

	requestHistory := GtLDataSourceEncoderDecoder loadClientHistoryFromStream: self ollamaJsonl1 readStream.
	chat := GtLChat new provider: (GtLOllamaProvider new
		modelName: 'qwen3.5:9b').
	constructor := GtLDataSourceMessageConstructor new
		requestHistory: requestHistory;
		chat: chat;
		parse.
	self assert: chat class identicalTo: GtLChat.
	self assert: chat messages size equals: 2.
	message := chat messages at: 1.
	self assert: message class identicalTo: GtLModelUserMessage.
	self assert: (message contentText beginsWith: '"\"Show me').
	self assert: message tools size equals: 1.
	self assert: message tools first class equals: GtLJsonPlaceholderTool.
	
	message := chat messages at: 2.
	self assert: message class equals: GtLReplyMessage.
	self assert: (message contentText beginsWith: '# WebFetch Tool Result').

	toolMessage := message executionMessages first.
	self assert: toolMessage class identicalTo: GtLToolMessage.
	self assert: toolMessage tools size equals: 1.
	self assert: toolMessage tools first class equals: GtLJsonPlaceholderTool.

	finalMessage := message finalMessage.
	self assert: finalMessage class identicalTo: GtLModelAssistantMessage.
	self assert: finalMessage tools size equals: 1.
	self assert: finalMessage tools first class equals: GtLJsonPlaceholderTool.

	^ chat
]

