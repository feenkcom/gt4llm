Class {
	#name : #GtLDataSourceEncoderExamples,
	#superclass : #Object,
	#traits : 'TAssertable',
	#classTraits : 'TAssertable classTrait',
	#category : #'Gt4Llm-DataSource-Examples'
}

{ #category : #examples }
GtLDataSourceEncoderExamples >> encodeRequestResponse [
	<gtExample>
	| requestResponse encoder stream encoded decoder decoded |

	requestResponse := GtLRequestResponse new
		request: self requests1 first;
		response: self responses1 first.
	encoder := GtLDataSourceEncoderDecoder new.
	stream := (String new: 1024) writeStream.
	encoder encode: requestResponse on: stream.
	encoded := stream contents.

	decoder := GtLDataSourceEncoderDecoder new.
	decoded := decoder decodeRequestResponseOn: encoded readStream.

	self assert: decoded class identicalTo: GtLRequestResponse.
	^ decoded
]

{ #category : #examples }
GtLDataSourceEncoderExamples >> encodeZnRequests [
	<gtExample>
	| encoder stream encoded decoder decoded |

	encoder := GtLDataSourceEncoderDecoder new.
	stream := (String new: 1024) writeStream.
	encoder encode: self requests1 first on: stream.
	encoded := stream contents.

	decoder := GtLDataSourceEncoderDecoder new.
	decoded := decoder decodeRequestOn: encoded readStream.

	self assert: decoded class identicalTo: ZnRequest.
	^ encoded
]

{ #category : #examples }
GtLDataSourceEncoderExamples >> encodeZnResponses [
	<gtExample>
	| encoder stream encoded decoder decoded |

	encoder := GtLDataSourceEncoderDecoder new.
	stream := (String new: 1024) writeStream.
	encoder encode: self responses1 first on: stream.
	encoded := stream contents.

	decoder := GtLDataSourceEncoderDecoder new.
	decoded := decoder decodeResponseOn: encoded readStream.

	self assert: decoded class identicalTo: ZnResponse.
	^ encoded
]

